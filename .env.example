# Copy to .env for local testing only. Real values are never committed --
# in deployment they come from Secrets Manager (see terraform/secrets.tf).

AWS_REGION=us-west-2

# Slack bot token (chat:write scope), used by server/slack_tools.py
SLACK_BOT_TOKEN=

# Default Slack channel posted to when a caller doesn't specify one
SLACK_CHANNEL=#daily-brief
